# Configuraciones de Entorno - JAAR Digital
# Copia este archivo como .env y rellena los valores reales.
# ATENCIÓN: Las variables con VITE_ son públicas en el cliente. No pongas secretos aquí a menos que sea intencional.

# === Configuración Local/Vite ===
VITE_APP_NAME="JAAR Digital Plataforma"
VITE_APP_VERSION="1.0.0"

# === Inteligencia Artificial ===
# Opcional: Si usas una API externa en lugar de window.ai local
VITE_AI_PROVIDER="local" # Opciones: "local", "openai", "claude"
VITE_OPENAI_API_KEY="sk-..."

# === Backend (Para futura migración de Dexie a Supabase/PHP) ===
VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu-anon-key"
